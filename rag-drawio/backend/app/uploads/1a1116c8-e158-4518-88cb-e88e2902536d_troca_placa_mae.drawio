        <mxCell id="e39" value="Sim" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fillColor=#d5e8d4;strokeColor=#82b366;" edge="1" source="35" target="37" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- Decisão estável → NÃO → investigar -->
        <mxCell id="e40" value="Não" style="edgeStyle=orthogonalEdgeStyle;fontStyle=1;fillColor=#f8cecc;strokeColor=#b85450;" edge="1" source="35" target="36" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- investigar → stress test (retry) -->
        <mxCell id="e41" value="Tentar novamente" style="edgeStyle=orthogonalEdgeStyle;fontStyle=2;" edge="1" source="36" target="34" parent="1">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="990" y="3495" />
              <mxPoint x="990" y="3370" />
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- fechar gabinete → FIM -->
        <mxCell id="e42" style="edgeStyle=orthogonalEdgeStyle;" edge="1" source="37" target="38" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
