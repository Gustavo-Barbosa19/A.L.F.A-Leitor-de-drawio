  <diagram name="Produção de Cerveja Artesanal" id="cerveja-artesanal">
    <mxGraphModel dx="1422" dy="762" grid="1" gridSize="10" pageWidth="1169" pageHeight="827">
      <root>
        <mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="2" value="INÍCIO&#xa;Definir receita e estilo" style="ellipse;fillColor=#7d6608;fontColor=#ffffff;strokeColor=#5d4e08;fontSize=13;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="450" y="30" width="240" height="65" as="geometry"/></mxCell>
        <mxCell id="3" value="Calcular ingredientes&#xa;(malte, lúpulo, levedura, água)&#xa;para o volume desejado" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="445" y="145" width="250" height="65" as="geometry"/></mxCell>
        <mxCell id="4" value="Tratar água:&#xa;ajustar pH e minerais&#xa;conforme perfil" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="445" y="260" width="250" height="60" as="geometry"/></mxCell>
        <mxCell id="5" value="MOSTURAÇÃO&#xa;Misturar malte moído&#xa;com água quente (65–72°C)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="445" y="370" width="250" height="65" as="geometry"/></mxCell>
        <mxCell id="6" value="Aguardar conversão&#xa;dos amidos (60–90 min)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="445" y="485" width="250" height="55" as="geometry"/></mxCell>
        <mxCell id="7" value="Teste do iodo:&#xa;conversão completa?" style="rhombus;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="445" y="590" width="250" height="85" as="geometry"/></mxCell>
        <mxCell id="8" value="Aguardar mais&#xa;15 min e testar&#xa;novamente" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="760" y="605" width="180" height="65" as="geometry"/></mxCell>
        <mxCell id="9" value="FILTRAGEM / LAVAGEM&#xa;Separar o mosto do bagaço&#xa;(vorlauf + sparging)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="445" y="730" width="250" height="65" as="geometry"/></mxCell>
        <mxCell id="10" value="Medir OG (Original Gravity)&#xa;conforme meta da receita?" style="rhombus;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="440" y="845" width="260" height="85" as="geometry"/></mxCell>
        <mxCell id="11" value="Ajustar: adicionar&#xa;açúcar (se baixo) ou&#xa;água (se alto)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="760" y="862" width="190" height="65" as="geometry"/></mxCell>
        <mxCell id="12" value="FERVURA (60–90 min)&#xa;Esterilizar e isomerizar&#xa;os ácidos do lúpulo" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="445" y="985" width="250" height="65" as="geometry"/></mxCell>
        <mxCell id="13" value="Adições de lúpulo&#xa;conforme cronograma&#xa;(bittering/flavor/aroma)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="445" y="1100" width="250" height="65" as="geometry"/></mxCell>
        <mxCell id="14" value="Resfriamento rápido&#xa;do mosto (< 25°C)&#xa;com chiller" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="445" y="1215" width="250" height="65" as="geometry"/></mxCell>
        <mxCell id="15" value="Transferir para&#xa;fermentador + oxigenar" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="445" y="1330" width="250" height="55" as="geometry"/></mxCell>
        <mxCell id="16" value="Inocular levedura&#xa;na temperatura correta" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="445" y="1435" width="250" height="55" as="geometry"/></mxCell>
        <mxCell id="17" value="FERMENTAÇÃO PRIMÁRIA&#xa;Aguardar 7–14 dias" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="445" y="1540" width="250" height="60" as="geometry"/></mxCell>
        <mxCell id="18" value="Atividade fermentativa&#xa;cessou? (airlock parado)" style="rhombus;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="440" y="1650" width="260" height="85" as="geometry"/></mxCell>
        <mxCell id="19" value="Aguardar mais&#xa;48–72h e retestar" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="760" y="1667" width="180" height="55" as="geometry"/></mxCell>
        <mxCell id="20" value="Dry hopping&#xa;necessário?" style="rhombus;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="445" y="1790" width="250" height="80" as="geometry"/></mxCell>
        <mxCell id="21" value="Adicionar lúpulo&#xa;a frio (3–5 dias)" style="rounded=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1"><mxGeometry x="760" y="1805" width="180" height="55" as="geometry"/></mxCell>
        <mxCell id="22" value="Maturação / Cold Crash&#xa;(0–2°C por 48–72h)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="445" y="1930" width="250" height="60" as="geometry"/></mxCell>
        <mxCell id="23" value="Carbonatação&#xa;(natural ou forçada CO2)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="445" y="2040" width="250" height="55" as="geometry"/></mxCell>
        <mxCell id="24" value="Envasamento&#xa;(garrafa, lata ou barril)" style="rounded=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1"><mxGeometry x="445" y="2145" width="250" height="55" as="geometry"/></mxCell>
        <mxCell id="25" value="Controle de qualidade&#xa;sensorial (cor, aroma, sabor)" style="rounded=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1"><mxGeometry x="445" y="2250" width="250" height="60" as="geometry"/></mxCell>
        <mxCell id="26" value="Aprovado&#xa;no QC?" style="rhombus;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="450" y="2360" width="240" height="80" as="geometry"/></mxCell>
        <mxCell id="27" value="Descartar lote e&#xa;revisar processo" style="rounded=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1"><mxGeometry x="760" y="2375" width="180" height="55" as="geometry"/></mxCell>
