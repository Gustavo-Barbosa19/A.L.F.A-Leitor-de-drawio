# OpenAI API (opcional - se nao configurado, usa busca semantica pura)
OPENAI_API_KEY=

# Modelo OpenAI (padrao: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini

# Qdrant (local)
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=drawio_flows

# Qdrant Cloud (para producao)
# QDRANT_HOST=xxxx-xxxx.us-east-1-0.aws.cloud.qdrant.io
# QDRANT_PORT=6333
# QDRANT_API_KEY=sua_chave_aqui

# Modelo de Embeddings
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Servidor
HOST=0.0.0.0
PORT=8000
